---
import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
---

<BaseLayout
  title="Clokki – Bald verfügbar"
  description="Clokki startet in Kürze. Trag dich auf die Warteliste ein und sei von Anfang an dabei."
  lang="de"
  canonical="https://clokki.de/soon"
>
  <Header />
  <main class="min-h-[calc(100vh-4rem)] flex items-center justify-center py-16 sm:py-24">
    <div class="mx-auto max-w-xl px-4 sm:px-6 text-center">
      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300">
        <span class="relative flex w-1.5 h-1.5">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full w-1.5 h-1.5 bg-blue-500"></span>
        </span>
        In Kürze verfügbar
      </span>

      <h1 class="mt-6 text-4xl sm:text-5xl font-semibold tracking-tight text-gray-900 dark:text-gray-100">
        Wir legen den letzten Schliff an.
      </h1>
      <p class="mt-4 text-base sm:text-lg text-gray-600 dark:text-gray-300">
        Clokki startet in den nächsten Wochen. Schreib uns kurz – wir melden uns, sobald du loslegen kannst. Keine Newsletter, kein Marketing.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="mailto:hallo@clokki.de?subject=Auf%20die%20Warteliste&body=Hallo%20Clokki-Team%2C%0A%0Aich%20m%C3%B6chte%20auf%20die%20Warteliste.%0A%0ATeamgr%C3%B6%C3%9Fe%3A%20%0ABundesland%3A%20%0A%0ADanke%21"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900"
        >
          Auf Warteliste
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
            <polyline points="22,6 12,13 2,6" />
          </svg>
        </a>
        <a
          href="/"
          class="inline-flex items-center justify-center px-6 py-3 text-sm font-medium text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700 rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900"
        >
          Zurück zur Startseite
        </a>
      </div>

      <p class="mt-8 text-xs text-gray-500 dark:text-gray-400">
        Öffnet deinen E-Mail-Client. Wir speichern deine Adresse nur, um dich beim Launch zu benachrichtigen.
      </p>
    </div>
  </main>
  <Footer />
</BaseLayout>
