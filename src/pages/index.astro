---
import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/Header.astro'
import Hero from '../components/Hero.astro'
import FeaturesGrid from '../components/FeaturesGrid.astro'
import HowItWorks from '../components/HowItWorks.astro'
import ComplianceCard from '../components/ComplianceCard.astro'
import FinalCta from '../components/FinalCta.astro'
import Footer from '../components/Footer.astro'
---

<BaseLayout
  title="Clokki – Zeiterfassung für deutsche Teams"
  description="Zeiterfassung, Überstunden und Urlaubsverwaltung. DSGVO-konform und kompatibel mit dem deutschen Arbeitsrecht. Made in Germany."
  lang="de"
  canonical="https://clokki.de/"
>
  <Header />
  <main>
    <Hero />
    <FeaturesGrid />
    <HowItWorks />
    <ComplianceCard />
    <FinalCta />
  </main>
  <Footer />
</BaseLayout>
