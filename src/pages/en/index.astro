---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Header from '../../components/Header.astro'
import Hero from '../../components/Hero.astro'
import FeaturesGrid from '../../components/FeaturesGrid.astro'
import HowItWorks from '../../components/HowItWorks.astro'
import ComplianceCard from '../../components/ComplianceCard.astro'
import FinalCta from '../../components/FinalCta.astro'
import Footer from '../../components/Footer.astro'
import { createT, type Lang } from '../../lib/i18n'

const lang: Lang = 'en'
const t = createT(lang)
---

<BaseLayout
  title={t('meta.indexTitle')}
  description={t('meta.indexDescription')}
  lang={lang}
  canonical="https://clokki.de/en/"
  altLang={{ lang: 'de', href: 'https://clokki.de/' }}
>
  <Header lang={lang} />
  <main>
    <Hero lang={lang} />
    <FeaturesGrid lang={lang} />
    <HowItWorks lang={lang} />
    <ComplianceCard lang={lang} />
    <FinalCta lang={lang} />
  </main>
  <Footer lang={lang} />
</BaseLayout>
