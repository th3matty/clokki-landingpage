---
import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import PricingTiers from '../components/PricingTiers.astro'
import PricingFaq from '../components/PricingFaq.astro'
import { createT, createTList, type Lang } from '../lib/i18n'

const lang: Lang = 'de'
const t = createT(lang)
const tList = createTList(lang)
const trust = tList('pricing.trustRow')
---

<BaseLayout
  title={t('meta.pricingTitle')}
  description={t('meta.pricingDescription')}
  lang={lang}
  canonical="https://clokki.de/preise"
  altLang={{ lang: 'en', href: 'https://clokki.de/en/preise' }}
>
  <Header lang={lang} />
  <main id="main">
    <!-- Hero -->
    <section class="pt-16 sm:pt-20 lg:pt-24 pb-8 sm:pb-12">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-3xl text-center">
          <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300">
            <span class="relative flex w-1.5 h-1.5">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full w-1.5 h-1.5 bg-blue-500"></span>
            </span>
            {t('pricing.badge')}
          </span>

          <h1 class="mt-6 text-4xl sm:text-5xl lg:text-6xl font-semibold tracking-tight text-gray-900 dark:text-gray-100">
            {t('pricing.title')}
          </h1>
          <p class="mt-4 text-base sm:text-lg text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
            {t('pricing.subtitle')}
          </p>

          <ul class="mt-8 flex flex-wrap gap-x-6 gap-y-2 justify-center text-sm text-gray-600 dark:text-gray-400">
            {trust.map((item) => (
              <li class="inline-flex items-center gap-2">
                <svg class="w-4 h-4 text-green-600 dark:text-green-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- Tiers -->
    <section class="pb-16 sm:pb-20">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <PricingTiers lang={lang} />
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-16 sm:py-20 border-t border-gray-200 dark:border-gray-800">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <PricingFaq lang={lang} />
      </div>
    </section>
  </main>
  <Footer lang={lang} />
</BaseLayout>
