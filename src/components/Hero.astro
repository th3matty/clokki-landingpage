---
import ProductPreview from './ProductPreview.astro'
import { createT, createTList, type Lang } from '../lib/i18n'

interface Props {
  lang?: Lang
}
const { lang = 'de' } = Astro.props
const t = createT(lang)
const tList = createTList(lang)
const trust = tList('hero.trust')
const soon = lang === 'en' ? '/en/soon' : '/soon'
---

<section class="relative pt-16 sm:pt-20 lg:pt-28 pb-12 sm:pb-16 lg:pb-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-semibold tracking-tight text-gray-900 dark:text-gray-100">
        {t('hero.title')}
      </h1>
      <p class="mt-6 text-lg sm:text-xl leading-relaxed text-gray-600 dark:text-gray-300">
        {t('hero.subtitle')}
      </p>

      <div class="mt-10 flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href={soon}
          class="inline-flex items-center justify-center gap-2 px-6 py-3 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900"
        >
          {t('hero.ctaPrimary')}
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </a>
        <a
          href="#funktionen"
          class="inline-flex items-center justify-center px-6 py-3 text-sm font-medium text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700 rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900"
        >
          {t('hero.ctaSecondary')}
        </a>
      </div>

      <ul class="mt-8 flex flex-wrap gap-x-6 gap-y-2 justify-center text-sm text-gray-600 dark:text-gray-400">
        {trust.map((item) => (
          <li class="inline-flex items-center gap-2">
            <svg class="w-4 h-4 text-green-600 dark:text-green-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="20 6 9 17 4 12" />
            </svg>
            {item}
          </li>
        ))}
      </ul>
    </div>

    <div class="mt-16 lg:mt-20">
      <ProductPreview lang={lang} />
    </div>
  </div>
</section>
