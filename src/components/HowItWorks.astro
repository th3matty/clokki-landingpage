---
const steps = [
  {
    number: 1,
    title: 'Team anlegen',
    description: 'Account erstellen, Bundesland wählen – Feiertage und Compliance werden automatisch konfiguriert.',
  },
  {
    number: 2,
    title: 'Mitglieder einladen',
    description: 'Team-ID teilen oder Mitglieder per E-Mail einladen. Rollen für Mitarbeiter und Admins.',
  },
  {
    number: 3,
    title: 'Loslegen',
    description: 'Zeiten erfassen, Anträge stellen, Genehmigungen verwalten – alles an einem Ort.',
  },
]
---

<section id="ablauf" class="py-16 sm:py-20 lg:py-24 border-t border-gray-200 dark:border-gray-800">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl sm:text-4xl font-semibold tracking-tight text-gray-900 dark:text-gray-100">
        In drei Schritten startklar
      </h2>
      <p class="mt-4 text-base sm:text-lg text-gray-600 dark:text-gray-300">
        Vom ersten Klick bis zur ersten Zeitbuchung in unter fünf Minuten.
      </p>
    </div>

    <ol class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-6">
      {steps.map((step, index) => (
        <li class="relative flex flex-col items-center text-center">
          <div class="flex items-center justify-center w-12 h-12 rounded-full bg-blue-600 text-white text-lg font-semibold shadow">
            {step.number}
          </div>
          {index < steps.length - 1 && (
            <span class="hidden md:block absolute top-6 left-[calc(50%+1.5rem+1rem)] w-[calc(100%-3rem-2rem)] h-px bg-gray-200 dark:bg-gray-700" aria-hidden="true"></span>
          )}
          <h3 class="mt-4 text-lg font-semibold text-gray-900 dark:text-gray-100">{step.title}</h3>
          <p class="mt-2 text-sm text-gray-600 dark:text-gray-300 leading-relaxed max-w-xs">{step.description}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
