---
interface Props {
  initials: string
  colorClass?: string
  size?: 'sm' | 'md' | 'lg'
}
const { initials, colorClass = 'bg-indigo-500 text-white', size = 'md' } = Astro.props
const sizeClass =
  size === 'sm' ? 'w-7 h-7 text-[10px]' :
  size === 'lg' ? 'w-10 h-10 text-sm' :
  'w-8 h-8 text-xs'
---
<span
  class:list={[
    'inline-flex items-center justify-center rounded-full font-semibold flex-shrink-0',
    sizeClass,
    colorClass,
  ]}
  aria-hidden="true"
>
  {initials}
</span>
