---
import Avatar from './Avatar.astro'

const members = [
  { name: 'Anna Schmidt', role: 'Designer', hours: '7,50h', color: 'bg-pink-500 text-white', initials: 'AS', status: 'on' },
  { name: 'Tim Becker', role: 'Developer', hours: '8,00h', color: 'bg-amber-500 text-white', initials: 'TB', status: 'on' },
  { name: 'Sophie Klein', role: 'PM', hours: '0,00h', color: 'bg-emerald-500 text-white', initials: 'SK', status: 'holiday' },
  { name: 'Lars Weber', role: 'Developer', hours: '6,25h', color: 'bg-sky-500 text-white', initials: 'LW', status: 'late' },
]

const activities = [
  { text: 'Anna hat 3 Tage Urlaub beantragt', time: 'vor 2 Std.', color: 'bg-blue-500' },
  { text: 'Tim hat Zeiteintrag korrigiert', time: 'vor 4 Std.', color: 'bg-orange-500' },
  { text: 'Sophie ist im Urlaub bis 24. Apr', time: 'gestern', color: 'bg-green-500' },
  { text: 'Lars hat Überstunden-Auszahlung angefragt', time: 'gestern', color: 'bg-blue-500' },
]

const statusDot = {
  on: 'bg-green-500',
  holiday: 'bg-emerald-500',
  late: 'bg-orange-500',
}

const statusLabel = {
  on: 'Aktiv',
  holiday: 'Urlaub',
  late: 'Verspätet',
}
---

<div class="bg-white dark:bg-gray-800">
  <div class="flex items-center gap-2 px-4 py-2.5 border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/50">
    <span class="w-2.5 h-2.5 rounded-full bg-red-400/70" aria-hidden="true"></span>
    <span class="w-2.5 h-2.5 rounded-full bg-yellow-400/70" aria-hidden="true"></span>
    <span class="w-2.5 h-2.5 rounded-full bg-green-400/70" aria-hidden="true"></span>
    <span class="ml-3 text-xs text-gray-500 dark:text-gray-400">app.clokki.de / admin</span>
  </div>

  <div class="p-5 sm:p-6 space-y-5">
    <!-- Header with stat pills -->
    <div class="flex flex-wrap items-center justify-between gap-3">
      <div>
        <h3 class="text-base sm:text-lg font-semibold text-gray-900 dark:text-gray-100">Admin-Dashboard</h3>
        <p class="text-xs text-gray-500 dark:text-gray-400">Team, Genehmigungen & Compliance</p>
      </div>
      <div class="flex items-center gap-2">
        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-200">
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          4 Mitglieder
        </span>
        <span class="relative inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-orange-100 dark:bg-orange-900/30 text-orange-700 dark:text-orange-300">
          <span class="relative flex w-1.5 h-1.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-orange-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full w-1.5 h-1.5 bg-orange-500"></span>
          </span>
          3 offen
        </span>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
      <!-- Team members (2/3) -->
      <div class="lg:col-span-2">
        <div class="flex items-center justify-between mb-2">
          <h4 class="text-sm font-semibold text-gray-900 dark:text-gray-100">Team-Mitglieder</h4>
          <span class="text-xs text-gray-500 dark:text-gray-400">Heute</span>
        </div>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          {members.map((m) => (
            <li class="flex items-center gap-3 px-3 py-2.5 rounded-lg border border-gray-200 dark:border-gray-700">
              <Avatar initials={m.initials} colorClass={m.color} size="md" />
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2">
                  <span class="text-sm font-medium text-gray-900 dark:text-gray-100 truncate">{m.name}</span>
                  <span class:list={['w-1.5 h-1.5 rounded-full flex-shrink-0', statusDot[m.status as keyof typeof statusDot]]} aria-hidden="true"></span>
                </div>
                <div class="text-[11px] text-gray-500 dark:text-gray-400 truncate">{m.role} · {statusLabel[m.status as keyof typeof statusLabel]}</div>
              </div>
              <div class="text-right flex-shrink-0">
                <div class="text-sm font-medium text-gray-900 dark:text-gray-100">{m.hours}</div>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <!-- Activity feed (1/3) -->
      <div>
        <h4 class="text-sm font-semibold text-gray-900 dark:text-gray-100 mb-2">Aktivität</h4>
        <ul class="space-y-2">
          {activities.map((a) => (
            <li class="flex items-start gap-2.5 px-3 py-2 rounded-lg bg-gray-50 dark:bg-gray-900/40">
              <span class:list={['flex-shrink-0 w-1.5 h-1.5 rounded-full mt-1.5', a.color]} aria-hidden="true"></span>
              <div class="min-w-0 flex-1">
                <p class="text-xs text-gray-700 dark:text-gray-200 leading-snug">{a.text}</p>
                <p class="text-[10px] text-gray-500 dark:text-gray-400 mt-0.5">{a.time}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</div>
