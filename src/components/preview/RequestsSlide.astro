---
import Avatar from './Avatar.astro'

const requests = [
  {
    initials: 'AS', color: 'bg-pink-500 text-white',
    name: 'Anna Schmidt',
    typeLabel: 'Urlaub',
    typeBadge: 'bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300',
    typeEmoji: '🏖️',
    typeBg: 'bg-blue-100 dark:bg-blue-900/30',
    dateRange: '22. Apr – 24. Apr 2026 · 3 Tage',
    reason: '"Familienbesuch"',
    breakdown: null,
  },
  {
    initials: 'TB', color: 'bg-amber-500 text-white',
    name: 'Tim Becker',
    typeLabel: 'Zeiteintrag',
    typeBadge: 'bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-300',
    typeEmoji: '⏰',
    typeBg: 'bg-purple-100 dark:bg-purple-900/30',
    dateRange: '15. Apr 2026',
    reason: '"Kundentermin war länger"',
    breakdown: { times: '09:00 – 18:30', lunch: '30 min', overtime: '+1,50h', total: '9,00h' },
  },
]
---

<!-- Simulated modal over blurred backdrop -->
<div class="relative bg-gray-100 dark:bg-gray-900 p-4 sm:p-6">
  <!-- Backdrop hint (dimmed dashboard) -->
  <div class="absolute inset-0 bg-gradient-to-b from-white/40 to-white/20 dark:from-gray-800/30 dark:to-gray-900/60 pointer-events-none" aria-hidden="true"></div>

  <div class="relative bg-white dark:bg-gray-800 rounded-lg shadow-xl max-w-3xl mx-auto overflow-hidden">
    <!-- Modal header -->
    <div class="px-5 py-3.5 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between">
      <div>
        <h3 class="text-base sm:text-lg font-semibold text-gray-900 dark:text-gray-100">Anfragen verwalten</h3>
        <p class="text-xs text-gray-600 dark:text-gray-400 mt-0.5">Urlaub, Zeiteinträge und Arbeitszeit-Hinweise</p>
      </div>
      <button type="button" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 p-1 rounded focus:outline-none focus:ring-2 focus:ring-blue-500" aria-label="Schließen">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Filter / stats bar -->
    <div class="px-5 py-3 border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/40">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <!-- Filter tabs (rounded pills, active=white shadow-sm) -->
        <div class="flex items-center gap-1">
          <button type="button" class="px-3 py-1.5 text-xs font-medium rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm" aria-current="page">
            Alle <span class="opacity-60">26</span>
          </button>
          <button type="button" class="px-3 py-1.5 text-xs font-medium rounded-md text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-200">
            Offen <span class="opacity-60">3</span>
          </button>
          <button type="button" class="px-3 py-1.5 text-xs font-medium rounded-md text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-200">
            Erledigt <span class="opacity-60">23</span>
          </button>
          <button type="button" class="ml-2 px-3 py-1.5 text-xs font-medium rounded-md text-amber-600 dark:text-amber-400 hover:text-amber-700 dark:hover:text-amber-300">
            Arbeitszeit <span class="opacity-60">0/12</span>
          </button>
        </div>

        <!-- Stats pills -->
        <div class="flex items-center gap-4 text-xs text-gray-600 dark:text-gray-400">
          <span class="inline-flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-orange-500"></span>Offen: 3</span>
          <span class="inline-flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-green-500"></span>Genehmigt: 18</span>
          <span class="inline-flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-red-500"></span>Abgelehnt: 5</span>
        </div>
      </div>

      <!-- Year + user dropdowns -->
      <div class="flex items-center gap-2 mt-2.5">
        <div class="inline-flex items-center gap-1 px-2.5 py-1 text-xs border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-200">
          2026
          <svg class="w-3 h-3 opacity-60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
        <div class="inline-flex items-center gap-1 px-2.5 py-1 text-xs border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-200">
          Alle Mitglieder
          <svg class="w-3 h-3 opacity-60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
      </div>
    </div>

    <!-- Content -->
    <div class="p-4 space-y-3">
      {requests.map((req) => (
        <article class="rounded-lg border border-gray-200 dark:border-gray-700 p-4">
          <div class="flex items-start gap-3">
            <!-- Avatar with type icon overlay -->
            <div class="relative flex-shrink-0">
              <Avatar initials={req.initials} colorClass={req.color} size="lg" />
              <span class:list={['absolute -bottom-0.5 -right-0.5 w-5 h-5 rounded-full flex items-center justify-center text-[10px] border-2 border-white dark:border-gray-800', req.typeBg]} aria-hidden="true">
                {req.typeEmoji}
              </span>
            </div>
            <div class="min-w-0 flex-1">
              <div class="flex flex-wrap items-center gap-x-2 gap-y-1">
                <span class="text-sm font-semibold text-gray-900 dark:text-gray-100">{req.name}</span>
                <span class:list={['inline-flex px-1.5 py-0.5 rounded text-[10px] font-medium', req.typeBadge]}>{req.typeLabel}</span>
                <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded-full text-[10px] font-medium bg-orange-100 dark:bg-orange-900/30 text-orange-700 dark:text-orange-300">
                  <span class="w-1 h-1 rounded-full bg-orange-500"></span> Offen
                </span>
              </div>
              <div class="mt-1.5 inline-flex items-center gap-1 text-xs text-gray-600 dark:text-gray-400">
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                <span class="font-medium">{req.dateRange}</span>
              </div>
              <p class="mt-1 text-xs italic text-orange-600 dark:text-orange-300">{req.reason}</p>
              {req.breakdown && (
                <dl class="mt-2 grid grid-cols-4 gap-2 text-[10px] text-gray-600 dark:text-gray-400 border-t border-gray-100 dark:border-gray-700 pt-2">
                  <div><dt class="opacity-70">Zeit</dt><dd class="font-medium text-gray-900 dark:text-gray-200">{req.breakdown.times}</dd></div>
                  <div><dt class="opacity-70">Pause</dt><dd class="font-medium text-gray-900 dark:text-gray-200">{req.breakdown.lunch}</dd></div>
                  <div><dt class="opacity-70">Überstunden</dt><dd class="font-medium text-green-600 dark:text-green-400">{req.breakdown.overtime}</dd></div>
                  <div><dt class="opacity-70">Gesamt</dt><dd class="font-medium text-gray-900 dark:text-gray-200">{req.breakdown.total}</dd></div>
                </dl>
              )}
            </div>
          </div>
          <div class="mt-3 flex items-center justify-end gap-2">
            <button type="button" class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-red-700 dark:text-red-300 bg-red-50 dark:bg-red-900/20 hover:bg-red-100 dark:hover:bg-red-900/40 border border-red-200 dark:border-red-800 rounded-md transition-colors">
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              Ablehnen
            </button>
            <button type="button" class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-white bg-green-600 hover:bg-green-700 rounded-md transition-colors shadow-sm">
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Genehmigen
            </button>
          </div>
        </article>
      ))}
    </div>
  </div>
</div>
