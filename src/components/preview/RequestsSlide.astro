---
import Avatar from './Avatar.astro'

const requests = [
  {
    initials: 'AS',
    color: 'bg-pink-500 text-white',
    name: 'Anna Schmidt',
    type: 'Urlaub',
    typeBadge: 'bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300',
    details: '22. Apr – 24. Apr 2026 · 3 Tage',
    reason: '"Familienbesuch"',
    status: 'pending',
  },
  {
    initials: 'TB',
    color: 'bg-amber-500 text-white',
    name: 'Tim Becker',
    type: 'Zeiteintrag-Korrektur',
    typeBadge: 'bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-300',
    details: '15. Apr · 09:00 – 18:30 statt 09:00 – 17:00',
    reason: '"Kundentermin war länger"',
    status: 'pending',
  },
]
---

<div class="bg-white dark:bg-gray-800">
  <div class="flex items-center gap-2 px-4 py-2.5 border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/50">
    <span class="w-2.5 h-2.5 rounded-full bg-red-400/70" aria-hidden="true"></span>
    <span class="w-2.5 h-2.5 rounded-full bg-yellow-400/70" aria-hidden="true"></span>
    <span class="w-2.5 h-2.5 rounded-full bg-green-400/70" aria-hidden="true"></span>
    <span class="ml-3 text-xs text-gray-500 dark:text-gray-400">Anfragen verwalten</span>
  </div>

  <div class="p-5 sm:p-6 space-y-4">
    <!-- Header -->
    <div class="flex items-start justify-between gap-3">
      <div>
        <h3 class="text-base sm:text-lg font-semibold text-gray-900 dark:text-gray-100">Anfragen verwalten</h3>
        <p class="text-xs text-gray-500 dark:text-gray-400">Urlaub, Zeiteinträge & Compliance</p>
      </div>
      <div class="hidden sm:flex items-center gap-3 text-xs text-gray-500 dark:text-gray-400">
        <span class="inline-flex items-center gap-1"><span class="w-1.5 h-1.5 rounded-full bg-orange-500"></span>Offen 3</span>
        <span class="inline-flex items-center gap-1"><span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>Genehmigt 18</span>
        <span class="inline-flex items-center gap-1"><span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>Abgelehnt 5</span>
      </div>
    </div>

    <!-- Filter tabs -->
    <div class="flex flex-wrap gap-1 border-b border-gray-200 dark:border-gray-700 -mb-px">
      <button type="button" class="px-3 py-2 text-xs font-medium text-gray-900 dark:text-gray-100 border-b-2 border-blue-600" aria-current="page">
        Alle <span class="text-gray-400 dark:text-gray-500">26</span>
      </button>
      <button type="button" class="px-3 py-2 text-xs font-medium text-gray-500 dark:text-gray-400 border-b-2 border-transparent hover:text-gray-700 dark:hover:text-gray-200">
        Offen <span class="text-gray-400 dark:text-gray-500">3</span>
      </button>
      <button type="button" class="px-3 py-2 text-xs font-medium text-gray-500 dark:text-gray-400 border-b-2 border-transparent hover:text-gray-700 dark:hover:text-gray-200">
        Erledigt <span class="text-gray-400 dark:text-gray-500">23</span>
      </button>
    </div>

    <!-- Request list -->
    <ul class="space-y-3">
      {requests.map((req) => (
        <li class="rounded-lg border border-gray-200 dark:border-gray-700 p-4">
          <div class="flex items-start gap-3">
            <Avatar initials={req.initials} colorClass={req.color} size="md" />
            <div class="min-w-0 flex-1">
              <div class="flex flex-wrap items-center gap-x-2 gap-y-1">
                <span class="text-sm font-medium text-gray-900 dark:text-gray-100">{req.name}</span>
                <span class:list={['inline-flex px-1.5 py-0.5 rounded text-[10px] font-medium', req.typeBadge]}>
                  {req.type}
                </span>
                <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded-full text-[10px] font-medium bg-orange-100 dark:bg-orange-900/30 text-orange-700 dark:text-orange-300">
                  <span class="w-1 h-1 rounded-full bg-orange-500"></span> Offen
                </span>
              </div>
              <p class="mt-1 text-xs text-gray-600 dark:text-gray-300">{req.details}</p>
              <p class="mt-1 text-xs italic text-gray-500 dark:text-gray-400">{req.reason}</p>
            </div>
          </div>
          <div class="mt-3 flex items-center gap-2 justify-end">
            <button type="button" class="px-3 py-1.5 text-xs font-medium text-red-700 dark:text-red-300 bg-red-50 dark:bg-red-900/20 hover:bg-red-100 dark:hover:bg-red-900/40 rounded-md transition-colors">
              Ablehnen
            </button>
            <button type="button" class="px-3 py-1.5 text-xs font-medium text-white bg-green-600 hover:bg-green-700 rounded-md transition-colors">
              Genehmigen
            </button>
          </div>
        </li>
      ))}
    </ul>
  </div>
</div>
