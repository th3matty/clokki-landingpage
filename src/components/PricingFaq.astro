---
import { createT, type Lang } from '../lib/i18n'
import de from '../i18n/de.json'
import en from '../i18n/en.json'

interface Props {
  lang?: Lang
}
const { lang = 'de' } = Astro.props
const t = createT(lang)
const dict = lang === 'en' ? en : de
const items = dict.pricing.faq.items
---

<section class="max-w-3xl mx-auto">
  <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight text-gray-900 dark:text-gray-100 text-center mb-10">
    {t('pricing.faq.heading')}
  </h2>

  <div class="space-y-3">
    {items.map((item) => (
      <details class="group rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 overflow-hidden">
        <summary class="cursor-pointer list-none px-5 py-4 flex items-center justify-between gap-4 text-sm font-medium text-gray-900 dark:text-gray-100 hover:bg-gray-50 dark:hover:bg-gray-700/50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-inset">
          <span>{item.q}</span>
          <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="6 9 12 15 18 9" />
          </svg>
        </summary>
        <div class="px-5 pb-5 pt-0 text-sm text-gray-600 dark:text-gray-300 leading-relaxed">
          {item.a}
        </div>
      </details>
    ))}
  </div>
</section>
