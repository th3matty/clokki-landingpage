---
// Mocked dashboard preview — pure HTML, no live data.
---

<div class="mx-auto max-w-5xl">
  <div class="rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 shadow-xl overflow-hidden">
    <!-- Window chrome -->
    <div class="flex items-center gap-2 px-4 py-3 border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/50">
      <span class="w-3 h-3 rounded-full bg-red-400/70" aria-hidden="true"></span>
      <span class="w-3 h-3 rounded-full bg-yellow-400/70" aria-hidden="true"></span>
      <span class="w-3 h-3 rounded-full bg-green-400/70" aria-hidden="true"></span>
      <span class="ml-3 text-xs text-gray-500 dark:text-gray-400">app.clokki.de — Dashboard</span>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-[180px_1fr]">
      <!-- Sidebar -->
      <aside class="hidden sm:flex flex-col gap-1 p-4 border-r border-gray-200 dark:border-gray-700 text-sm text-gray-600 dark:text-gray-300">
        <div class="px-3 py-2 rounded-md bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 font-medium">Übersicht</div>
        <div class="px-3 py-2 rounded-md hover:bg-gray-100 dark:hover:bg-gray-700">Zeiterfassung</div>
        <div class="px-3 py-2 rounded-md hover:bg-gray-100 dark:hover:bg-gray-700">Urlaub</div>
        <div class="px-3 py-2 rounded-md hover:bg-gray-100 dark:hover:bg-gray-700">Anträge</div>
        <div class="px-3 py-2 rounded-md hover:bg-gray-100 dark:hover:bg-gray-700">Kalender</div>
      </aside>

      <!-- Content -->
      <div class="p-4 sm:p-6 space-y-6">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100">Heute · 6h 24m</h3>
            <p class="text-xs text-gray-500 dark:text-gray-400">09:00 – 17:30 · 60 min Pause</p>
          </div>
          <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300">
            <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span> Erfasst
          </span>
        </div>

        <!-- Stats grid -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
          <div class="rounded-lg border border-gray-200 dark:border-gray-700 p-3">
            <div class="text-xs text-gray-500 dark:text-gray-400">Wochenziel</div>
            <div class="mt-1 text-2xl font-semibold text-gray-900 dark:text-gray-100">80%</div>
            <div class="mt-2 h-1.5 rounded-full bg-gray-100 dark:bg-gray-700 overflow-hidden">
              <div class="h-full w-4/5 bg-blue-600 rounded-full"></div>
            </div>
          </div>
          <div class="rounded-lg border border-gray-200 dark:border-gray-700 p-3">
            <div class="text-xs text-gray-500 dark:text-gray-400">Überstunden</div>
            <div class="mt-1 text-2xl font-semibold text-green-600 dark:text-green-400">+2h 15m</div>
            <div class="mt-1 text-xs text-gray-500 dark:text-gray-400">Saldo aktuell</div>
          </div>
          <div class="rounded-lg border border-gray-200 dark:border-gray-700 p-3">
            <div class="text-xs text-gray-500 dark:text-gray-400">Resturlaub</div>
            <div class="mt-1 text-2xl font-semibold text-gray-900 dark:text-gray-100">18</div>
            <div class="mt-1 text-xs text-gray-500 dark:text-gray-400">Tage</div>
          </div>
          <div class="rounded-lg border border-gray-200 dark:border-gray-700 p-3">
            <div class="text-xs text-gray-500 dark:text-gray-400">Krankentage</div>
            <div class="mt-1 text-2xl font-semibold text-gray-900 dark:text-gray-100">3</div>
            <div class="mt-1 text-xs text-gray-500 dark:text-gray-400">dieses Jahr</div>
          </div>
        </div>

        <!-- Week strip -->
        <div>
          <div class="text-xs text-gray-500 dark:text-gray-400 mb-2">Diese Woche</div>
          <div class="grid grid-cols-5 gap-2">
            {['Mo', 'Di', 'Mi', 'Do', 'Fr'].map((day, i) => (
              <div class="rounded-md border border-gray-200 dark:border-gray-700 p-2 text-center">
                <div class="text-xs text-gray-500 dark:text-gray-400">{day}</div>
                <div class="mt-1 text-sm font-medium text-gray-900 dark:text-gray-100">
                  {i < 4 ? '8h' : '6.4h'}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
