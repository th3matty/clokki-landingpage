---
import EmployeeSlide from './preview/EmployeeSlide.astro'
import AdminSlide from './preview/AdminSlide.astro'
import RequestsSlide from './preview/RequestsSlide.astro'
import { createT, type Lang } from '../lib/i18n'

interface Props {
  lang?: Lang
}
const { lang = 'de' } = Astro.props
const t = createT(lang)

const slides = [
  { id: 'preview-employee', label: t('preview.tabs.employee'), sr: t('preview.tabs.employeeSr') },
  { id: 'preview-admin',    label: t('preview.tabs.admin'),    sr: t('preview.tabs.adminSr') },
  { id: 'preview-requests', label: t('preview.tabs.requests'), sr: t('preview.tabs.requestsSr') },
]
---

<section aria-label={t('preview.ariaLabel')} class="mx-auto max-w-5xl">
  <div class="rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 shadow-xl overflow-hidden">
    <div role="tablist" aria-label={t('preview.tablistAria')} class="flex items-center gap-1 px-3 py-2 border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/50 overflow-x-auto">
      {slides.map((slide, i) => (
        <button
          type="button"
          role="tab"
          data-target={slide.id}
          id={`tab-${slide.id}`}
          aria-controls={slide.id}
          aria-selected={i === 0 ? 'true' : 'false'}
          class:list={[
            'preview-tab relative px-3 py-1.5 text-xs sm:text-sm font-medium rounded-md transition-colors whitespace-nowrap focus:outline-none focus:ring-2 focus:ring-blue-500',
            i === 0
              ? 'bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 shadow-sm'
              : 'text-gray-600 dark:text-gray-300 hover:bg-white/60 dark:hover:bg-gray-800/60',
          ]}
        >
          {slide.label}
          <span class="sr-only"> – {slide.sr}</span>
        </button>
      ))}
    </div>

    <div
      id="preview-slider"
      class="preview-slider flex overflow-x-auto snap-x snap-mandatory scroll-smooth"
      tabindex="0"
      aria-label={t('preview.sliderAria')}
    >
      {slides.map((slide) => (
        <div
          id={slide.id}
          role="tabpanel"
          aria-labelledby={`tab-${slide.id}`}
          class="snap-start shrink-0 w-full"
        >
          {slide.id === 'preview-employee' && <EmployeeSlide />}
          {slide.id === 'preview-admin' && <AdminSlide />}
          {slide.id === 'preview-requests' && <RequestsSlide />}
        </div>
      ))}
    </div>
  </div>

  <div class="mt-4 flex items-center justify-center gap-2" aria-hidden="true">
    {slides.map((_, i) => (
      <span
        class:list={[
          'preview-dot w-2 h-2 rounded-full transition-colors',
          i === 0 ? 'bg-blue-600' : 'bg-gray-300 dark:bg-gray-600',
        ]}
      ></span>
    ))}
  </div>
</section>

<style>
  .preview-slider {
    scrollbar-width: none;
  }
  .preview-slider::-webkit-scrollbar {
    display: none;
  }
</style>

<script is:inline>
  ;(() => {
    const slider = document.getElementById('preview-slider')
    if (!slider) return
    const tabs = Array.from(document.querySelectorAll('.preview-tab'))
    const dots = Array.from(document.querySelectorAll('.preview-dot'))
    const panels = tabs.map((t) => document.getElementById(t.getAttribute('data-target')))

    function activate(index) {
      tabs.forEach((tab, i) => {
        const active = i === index
        tab.setAttribute('aria-selected', active ? 'true' : 'false')
        tab.classList.toggle('bg-white', active)
        tab.classList.toggle('dark:bg-gray-800', active)
        tab.classList.toggle('text-gray-900', active)
        tab.classList.toggle('dark:text-gray-100', active)
        tab.classList.toggle('shadow-sm', active)
        tab.classList.toggle('text-gray-600', !active)
        tab.classList.toggle('dark:text-gray-300', !active)
      })
      dots.forEach((dot, i) => {
        const active = i === index
        dot.classList.toggle('bg-blue-600', active)
        dot.classList.toggle('bg-gray-300', !active)
        dot.classList.toggle('dark:bg-gray-600', !active)
      })
    }

    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => {
        const panel = panels[i]
        if (!panel) return
        slider.scrollTo({ left: panel.offsetLeft - slider.offsetLeft, behavior: 'smooth' })
      })
    })

    let ticking = false
    slider.addEventListener('scroll', () => {
      if (ticking) return
      ticking = true
      requestAnimationFrame(() => {
        const scroll = slider.scrollLeft
        const width = slider.clientWidth
        const idx = Math.round(scroll / width)
        activate(Math.max(0, Math.min(idx, tabs.length - 1)))
        ticking = false
      })
    })
  })()
</script>
