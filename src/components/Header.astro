---
import Logo from './Logo.astro'
import ThemeToggle from './ThemeToggle.vue'
import { createT, type Lang } from '../lib/i18n'

interface Props {
  lang?: Lang
}
const { lang = 'de' } = Astro.props
const t = createT(lang)
const home = lang === 'en' ? '/en/' : '/'
const soon = lang === 'en' ? '/en/soon' : '/soon'
const pricing = lang === 'en' ? '/en/preise' : '/preise'
---

<header class="sticky top-0 z-40 w-full border-b border-gray-200 dark:border-gray-800 bg-white/80 dark:bg-gray-900/80 backdrop-blur supports-[backdrop-filter]:bg-white/60 dark:supports-[backdrop-filter]:bg-gray-900/60">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between gap-4">
    <Logo lang={lang} />

    <nav class="hidden md:flex items-center gap-8 text-sm text-gray-600 dark:text-gray-300" aria-label={t('header.navAria')}>
      <a href={`${home}#funktionen`} class="hover:text-gray-900 dark:hover:text-gray-100 transition-colors">{t('header.features')}</a>
      <a href={`${home}#ablauf`} class="hover:text-gray-900 dark:hover:text-gray-100 transition-colors">{t('header.howItWorks')}</a>
      <a href={`${home}#compliance`} class="hover:text-gray-900 dark:hover:text-gray-100 transition-colors">{t('header.compliance')}</a>
      <a href={pricing} class="hover:text-gray-900 dark:hover:text-gray-100 transition-colors">{t('header.pricing')}</a>
    </nav>

    <div class="flex items-center gap-2">
      <ThemeToggle client:load />
      <a
        href={soon}
        class="hidden sm:inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900"
      >
        {t('header.login')}
      </a>
    </div>
  </div>
</header>
