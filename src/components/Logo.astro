---
interface Props {
  class?: string
}
const { class: className = '' } = Astro.props
---

<a
  href="/"
  class:list={[
    'inline-flex items-center gap-2 font-semibold text-gray-900 dark:text-gray-100 hover:opacity-80 transition-opacity focus:outline-none focus:ring-2 focus:ring-blue-500 rounded-md',
    className,
  ]}
  aria-label="Clokki – Startseite"
>
  <span class="inline-flex items-center justify-center w-8 h-8 rounded-md bg-blue-600 text-white">
    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="10" />
      <polyline points="12 6 12 12 16 14" />
    </svg>
  </span>
  <span class="text-lg tracking-tight">clokki</span>
</a>
