---
import { createT, createTList, type Lang } from '../lib/i18n'

interface Props {
  lang?: Lang
}
const { lang = 'de' } = Astro.props
const t = createT(lang)
const tList = createTList(lang)
const points = tList('compliance.points')
---

<section id="compliance" class="py-16 sm:py-20 lg:py-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl rounded-lg border border-blue-200 dark:border-blue-800 bg-blue-50 dark:bg-blue-900/20 p-6 sm:p-8">
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0 inline-flex items-center justify-center w-10 h-10 rounded-md bg-blue-600 text-white">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
          </svg>
        </div>
        <div class="flex-1">
          <h2 class="text-xl sm:text-2xl font-semibold text-gray-900 dark:text-gray-100">
            {t('compliance.title')}
          </h2>
          <p class="mt-2 text-sm sm:text-base text-gray-700 dark:text-gray-300">
            {t('compliance.subtitle')}
          </p>

          <ul class="mt-5 grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3">
            {points.map((point) => (
              <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-200">
                <svg class="w-4 h-4 mt-0.5 text-blue-600 dark:text-blue-400 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                <span>{point}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
