---
import Logo from './Logo.astro'
import ThemeToggle from './ThemeToggle.vue'

const currentYear = new Date().getFullYear()

const linkColumns = [
  {
    heading: 'Produkt',
    links: [
      { label: 'Funktionen', href: '#funktionen' },
      { label: 'Ablauf', href: '#ablauf' },
      { label: 'Compliance', href: '#compliance' },
    ],
  },
  {
    heading: 'Unternehmen',
    links: [
      { label: 'Über uns', href: '#' },
      { label: 'Kontakt', href: 'mailto:hallo@clokki.de' },
    ],
  },
  {
    heading: 'Rechtliches',
    links: [
      { label: 'Impressum', href: '/impressum' },
      { label: 'Datenschutz', href: '/datenschutz' },
      { label: 'AGB', href: '/agb' },
    ],
  },
]
---

<footer class="border-t border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <div class="col-span-2 md:col-span-1">
        <Logo />
        <p class="mt-4 text-sm text-gray-600 dark:text-gray-400 max-w-xs">
          Zeiterfassung für deutsche Teams. Einfach, konform, transparent.
        </p>
      </div>
      {linkColumns.map((column) => (
        <div>
          <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100">{column.heading}</h3>
          <ul class="mt-4 space-y-3">
            {column.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-800 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-gray-500 dark:text-gray-400">
        © {currentYear} Clokki · Made with ♥ in Germany
      </p>
      <div class="flex items-center gap-3">
        <a href="/en" class="text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 transition-colors" hreflang="en">
          EN
        </a>
        <span class="text-gray-300 dark:text-gray-700" aria-hidden="true">·</span>
        <a href="/" class="text-sm font-medium text-gray-900 dark:text-gray-100" aria-current="page" hreflang="de">
          DE
        </a>
        <span class="text-gray-300 dark:text-gray-700 ml-2" aria-hidden="true">|</span>
        <ThemeToggle client:load />
      </div>
    </div>
  </div>
</footer>
