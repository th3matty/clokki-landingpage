---
import Logo from './Logo.astro'
import ThemeToggle from './ThemeToggle.vue'
import { createT, type Lang } from '../lib/i18n'

interface Props {
  lang?: Lang
}
const { lang = 'de' } = Astro.props
const t = createT(lang)
const currentYear = new Date().getFullYear()
const home = lang === 'en' ? '/en/' : '/'
const pricing = lang === 'en' ? '/en/preise' : '/preise'

const linkColumns = [
  {
    heading: t('footer.columnProduct'),
    links: [
      { label: t('header.features'), href: `${home}#funktionen` },
      { label: t('header.howItWorks'), href: `${home}#ablauf` },
      { label: t('header.compliance'), href: `${home}#compliance` },
      { label: t('header.pricing'), href: pricing },
    ],
  },
  {
    heading: t('footer.columnLegal'),
    links: [
      { label: 'Impressum', href: '/impressum' },
      { label: 'Datenschutz', href: '/datenschutz' },
    ],
  },
]
---

<footer class="border-t border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
      <div class="sm:col-span-1">
        <Logo lang={lang} />
        <p class="mt-4 text-sm text-gray-600 dark:text-gray-400 max-w-xs">
          {t('footer.tagline')}
        </p>
      </div>
      {linkColumns.map((column) => (
        <div>
          <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100">{column.heading}</h3>
          <ul class="mt-4 space-y-3">
            {column.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-800 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-gray-500 dark:text-gray-400">
        © {currentYear} Clokki · {t('footer.copyright')}
      </p>
      <div class="flex items-center gap-3" aria-label={t('footer.languageSwitchAria')}>
        <a
          href="/en/"
          class:list={[
            'text-sm transition-colors',
            lang === 'en'
              ? 'font-medium text-gray-900 dark:text-gray-100'
              : 'text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100',
          ]}
          aria-current={lang === 'en' ? 'page' : undefined}
          hreflang="en"
        >
          EN
        </a>
        <span class="text-gray-300 dark:text-gray-700" aria-hidden="true">·</span>
        <a
          href="/"
          class:list={[
            'text-sm transition-colors',
            lang === 'de'
              ? 'font-medium text-gray-900 dark:text-gray-100'
              : 'text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100',
          ]}
          aria-current={lang === 'de' ? 'page' : undefined}
          hreflang="de"
        >
          DE
        </a>
        <span class="text-gray-300 dark:text-gray-700 ml-2" aria-hidden="true">|</span>
        <ThemeToggle client:load />
      </div>
    </div>
  </div>
</footer>
